<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<TabPane maxHeight="-Infinity" maxWidth="-Infinity" minHeight="-Infinity" minWidth="-Infinity" prefHeight="400.0" prefWidth="600.0" tabClosingPolicy="UNAVAILABLE" xmlns:fx="http://javafx.com/fxml/1" xmlns="http://javafx.com/javafx/17" fx:controller="com.example.videorentalsystem.HelloController">
    <tabs>
        <Tab text="Genres">
            <content>
                <AnchorPane minHeight="0.0" minWidth="0.0" prefHeight="180.0" prefWidth="200.0">
                    <children>
                        <Label layoutX="14.0" layoutY="27.0" text="Genre Name:" />
                        <TextField fx:id="txtGenreName" layoutX="101.0" layoutY="23.0" />
                        <Button layoutX="101.0" layoutY="65.0" mnemonicParsing="Parsing" onAction="#onSaveGenreClick" text="Save Genre" />
                        <ListView fx:id="listGenres" layoutX="300.0" layoutY="23.0" prefHeight="300.0" prefWidth="250.0" />
                    </children>
                </AnchorPane>
            </content>
        </Tab>
        <Tab text="Movies">
            <content>
                <AnchorPane minHeight="0.0" minWidth="0.0" prefHeight="180.0" prefWidth="200.0">
                    <children>
                        <Label layoutX="14.0" layoutY="27.0" text="Movie Title:" />
                        <TextField fx:id="txtMovieTitle" layoutX="101.0" layoutY="23.0" />

                        <Label layoutX="14.0" layoutY="65.0" text="Pick Genre:" />
                        <ComboBox fx:id="comboMovieGenre" layoutX="101.0" layoutY="61.0" prefWidth="150.0" />

                        <Button layoutX="101.0" layoutY="105.0" onAction="#onSaveMovieClick" text="Save Movie" />

                        <ListView fx:id="listMovies" layoutX="300.0" layoutY="23.0" prefHeight="300.0" prefWidth="250.0" />
                    </children>
                </AnchorPane>
            </content>
        </Tab>
        <Tab text="Customers">
            <content>
                <AnchorPane prefHeight="180.0" prefWidth="200.0">
                    <children>
                        <Label layoutX="14.0" layoutY="27.0" text="Customer Name:" />
                        <TextField fx:id="txtCustomerName" layoutX="120.0" layoutY="23.0" />
                        <Button layoutX="120.0" layoutY="65.0" onAction="#onSaveCustomerClick" text="Add Customer" />
                        <ListView fx:id="listCustomers" layoutX="300.0" layoutY="23.0" prefHeight="300.0" prefWidth="250.0" />
                    </children>
                </AnchorPane>
            </content>
        </Tab>
        <Tab text="Rentals">
            <content>
                <AnchorPane prefHeight="180.0" prefWidth="200.0">
                    <children>
                        <Label layoutX="14.0" layoutY="27.0" text="Select Customer:" />
                        <ComboBox fx:id="comboRentalCustomer" layoutX="120.0" layoutY="23.0" prefWidth="150.0" />

                        <Label layoutX="14.0" layoutY="65.0" text="Select Movie:" />
                        <ComboBox fx:id="comboRentalMovie" layoutX="120.0" layoutY="61.0" prefWidth="150.0" />

                        <Button layoutX="120.0" layoutY="105.0" onAction="#onRentMovieClick" text="Rent Movie" />
                        <ListView fx:id="listRentals" layoutX="300.0" layoutY="23.0" prefHeight="300.0" prefWidth="250.0" />
                    </children>
                </AnchorPane>
            </content>
        </Tab>
    </tabs>
</TabPane>